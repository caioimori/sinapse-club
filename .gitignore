# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Environment & Secrets (SINAPSE)
.env
.env.local
.env.*.local
*.key

# Dependencies (SINAPSE)
node_modules/

# Build & Logs (SINAPSE)
dist/
build/
*.log
logs/

# IDE & OS (SINAPSE)
Thumbs.db
.idea/
*.swp

# SINAPSE Local (SINAPSE)
.sinapse-ai/local/
.claude/settings.local.json
.sinapse/install-log.txt

# SINAPSE runtime artifacts
.sinapse-ai/.cache/
.sinapse-ai/.tmp/

# Supabase temp files
supabase/.temp/

.vercel

# Runtime scratchpad and lockfiles (never commit)
.sinapse/scratchpad/
.claude/scheduled_tasks.lock
