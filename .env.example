# ============================================
# SINAPSE Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage)
# NEXT_PUBLIC_* values are required by the Next.js app at build time
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=

# AbacatePay (DEPRECATED — em fade-out, sera removido apos 30 dias de Stripe estavel)
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
# Optional override for webhook signature verification
ABACATEPAY_WEBHOOK_PUBLIC_KEY=

# --------------------------------------------
# Stripe (Custom Checkout — STRIPE-2.1)
# --------------------------------------------
# Feature flag: "stripe" ativa Stripe Payment Element no /checkout/[plano].
# Default "abacatepay" mantem fluxo legado. Mudar pra "stripe" no Vercel
# apos KYC aprovado, Price IDs configurados e webhook criado no Stripe Dashboard.
PAYMENT_PROVIDER=abacatepay

# Stripe API keys — Matheus pega no dashboard Stripe (Developers > API keys).
# Test mode: sk_test_* / pk_test_*. Live mode: sk_live_* / pk_live_*.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — capturado ao criar webhook endpoint no Stripe Dashboard
# (Developers > Webhooks > Add endpoint > apontando pra https://sinapse.club/api/webhooks/stripe).
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — criados pelo Soier no dashboard apos KYC (Products > Add product > Recurring).
# Placeholders aqui pra Caio testar local com Stripe test mode usando IDs de teste do Soier.
STRIPE_PRICE_MENSAL=price_PLACEHOLDER_MENSAL
STRIPE_PRICE_SEMESTRAL=price_PLACEHOLDER_SEMESTRAL
STRIPE_PRICE_ANUAL=price_PLACEHOLDER_ANUAL

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# SINAPSE Core Configuration
# --------------------------------------------
NODE_ENV=development
SINAPSE_VERSION=2.2.0

# --------------------------------------------
# Rate Limiting
# --------------------------------------------

# Upstash Redis (rate limiting) — get from upstash.com (free tier is enough)
UPSTASH_REDIS_REST_URL=your_url_here
UPSTASH_REDIS_REST_TOKEN=your_token_here

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below
